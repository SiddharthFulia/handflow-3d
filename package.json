{
  "name": "handflow-3d",
  "version": "0.1.0",
  "description": "Browser 3D endless-runner controlled by hand gestures. Three.js + React + MediaPipe Tasks Vision.",
  "type": "module",
  "license": "MIT",
  "author": "Siddharth Fulia",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.158.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "three.js",
    "mediapipe",
    "hand-gesture",
    "endless-runner",
    "webgl",
    "react"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
